        "categories": { "x": 480, "y": 60 },
        "products": { "x": 480, "y": 320 },
        "stock_levels": { "x": 920, "y": 60 },
        "stock_movements": { "x": 920, "y": 380 },
        "suppliers": { "x": 1360, "y": 60 },
