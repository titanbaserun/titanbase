    { "id": "categories_parent", "name": "categories_parent", "from": { "table": "categories", "columns": ["categories.parent_id"] }, "to": { "table": "categories", "columns": ["categories.id"] }, "cardinality": "many-to-one", "onDelete": "set-null" },
    { "id": "products_category", "name": "products_category", "from": { "table": "products", "columns": ["products.category_id"] }, "to": { "table": "categories", "columns": ["categories.id"] }, "cardinality": "many-to-one", "onDelete": "set-null" },
    { "id": "stock_levels_product", "name": "stock_levels_product", "from": { "table": "stock_levels", "columns": ["stock_levels.product_id"] }, "to": { "table": "products", "columns": ["products.id"] }, "cardinality": "many-to-one", "onDelete": "cascade" },
    { "id": "stock_levels_zone", "name": "stock_levels_zone", "from": { "table": "stock_levels", "columns": ["stock_levels.zone_id"] }, "to": { "table": "zones", "columns": ["zones.id"] }, "cardinality": "many-to-one", "onDelete": "cascade" },
    { "id": "stock_movements_product", "name": "stock_movements_product", "from": { "table": "stock_movements", "columns": ["stock_movements.product_id"] }, "to": { "table": "products", "columns": ["products.id"] }, "cardinality": "many-to-one", "onDelete": "restrict" },
    { "id": "stock_movements_from_zone", "name": "stock_movements_from_zone", "from": { "table": "stock_movements", "columns": ["stock_movements.from_zone_id"] }, "to": { "table": "zones", "columns": ["zones.id"] }, "cardinality": "many-to-one", "onDelete": "restrict" },
    { "id": "stock_movements_to_zone", "name": "stock_movements_to_zone", "from": { "table": "stock_movements", "columns": ["stock_movements.to_zone_id"] }, "to": { "table": "zones", "columns": ["zones.id"] }, "cardinality": "many-to-one", "onDelete": "restrict" },
    { "id": "product_suppliers_product", "name": "product_suppliers_product", "from": { "table": "product_suppliers", "columns": ["product_suppliers.product_id"] }, "to": { "table": "products", "columns": ["products.id"] }, "cardinality": "many-to-one", "onDelete": "cascade" },
    { "id": "product_suppliers_supplier", "name": "product_suppliers_supplier", "from": { "table": "product_suppliers", "columns": ["product_suppliers.supplier_id"] }, "to": { "table": "suppliers", "columns": ["suppliers.id"] }, "cardinality": "many-to-one", "onDelete": "cascade" }
  ],
