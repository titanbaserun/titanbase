{
  "titanVersion": "1.0",
  "project": { "id": "messaging", "name": "Real-time Messaging" },
  "dialect": "postgres",
  "tables": [
    {
      "id": "users", "name": "users", "description": "Registered platform users.",
      "columns": [
        { "id": "users.id", "name": "id", "type": "uuid", "nullable": false, "primaryKey": true, "unique": true, "default": "gen_random_uuid()" },
        { "id": "users.username", "name": "username", "type": "text", "nullable": false, "primaryKey": false, "unique": true },
        { "id": "users.email", "name": "email", "type": "text", "nullable": false, "primaryKey": false, "unique": true },
        { "id": "users.password_hash", "name": "password_hash", "type": "text", "nullable": false, "primaryKey": false, "unique": false },
        { "id": "users.display_name", "name": "display_name", "type": "text", "nullable": false, "primaryKey": false, "unique": false },
        { "id": "users.avatar_url", "name": "avatar_url", "type": "text", "nullable": true, "primaryKey": false, "unique": false },
        { "id": "users.status", "name": "status", "type": "user_presence", "nullable": false, "primaryKey": false, "unique": false, "default": "'offline'" },
        { "id": "users.last_seen_at", "name": "last_seen_at", "type": "timestamptz", "nullable": true, "primaryKey": false, "unique": false },
        { "id": "users.created_at", "name": "created_at", "type": "timestamptz", "nullable": false, "primaryKey": false, "unique": false, "default": "now()" }
      ],
      "indexes": []
    },
    {
      "id": "channels", "name": "channels", "description": "Group conversations or direct message threads.",
      "columns": [
        { "id": "channels.id", "name": "id", "type": "uuid", "nullable": false, "primaryKey": true, "unique": true, "default": "gen_random_uuid()" },
        { "id": "channels.type", "name": "type", "type": "channel_type", "nullable": false, "primaryKey": false, "unique": false },
        { "id": "channels.name", "name": "name", "type": "text", "nullable": true, "primaryKey": false, "unique": false, "description": "Null for direct messages." },
        { "id": "channels.description", "name": "description", "type": "text", "nullable": true, "primaryKey": false, "unique": false },
        { "id": "channels.is_private", "name": "is_private", "type": "boolean", "nullable": false, "primaryKey": false, "unique": false, "default": "false" },
        { "id": "channels.created_by", "name": "created_by", "type": "uuid", "nullable": false, "primaryKey": false, "unique": false },
        { "id": "channels.created_at", "name": "created_at", "type": "timestamptz", "nullable": false, "primaryKey": false, "unique": false, "default": "now()" }
      ],
      "indexes": [{ "id": "channels.type_idx", "name": "channels_type_idx", "table": "channels", "columns": ["channels.type"], "unique": false }, { "id": "channels.created_by_idx", "name": "channels_created_by_idx", "table": "channels", "columns": ["channels.created_by"], "unique": false }]
    },
    {
      "id": "channel_members", "name": "channel_members", "description": "Users participating in a channel.",
      "columns": [
        { "id": "channel_members.channel_id", "name": "channel_id", "type": "uuid", "nullable": false, "primaryKey": true, "unique": false },
        { "id": "channel_members.user_id", "name": "user_id", "type": "uuid", "nullable": false, "primaryKey": true, "unique": false },
        { "id": "channel_members.role", "name": "role", "type": "member_role", "nullable": false, "primaryKey": false, "unique": false, "default": "'member'" },
        { "id": "channel_members.muted", "name": "muted", "type": "boolean", "nullable": false, "primaryKey": false, "unique": false, "default": "false" },
        { "id": "channel_members.joined_at", "name": "joined_at", "type": "timestamptz", "nullable": false, "primaryKey": false, "unique": false, "default": "now()" },
        { "id": "channel_members.last_read_at", "name": "last_read_at", "type": "timestamptz", "nullable": true, "primaryKey": false, "unique": false }
      ],
      "indexes": [{ "id": "channel_members.user_idx", "name": "channel_members_user_idx", "table": "channel_members", "columns": ["channel_members.user_id"], "unique": false }, { "id": "channel_members.channel_members_channel_id_idx", "name": "channel_members_channel_id_idx", "table": "channel_members", "columns": ["channel_members.channel_id"], "unique": false, "method": "btree" }]
    },
    {
      "id": "messages", "name": "messages", "description": "Individual messages sent in channels.",
      "columns": [
        { "id": "messages.id", "name": "id", "type": "uuid", "nullable": false, "primaryKey": true, "unique": true, "default": "gen_random_uuid()" },
        { "id": "messages.channel_id", "name": "channel_id", "type": "uuid", "nullable": false, "primaryKey": false, "unique": false },
        { "id": "messages.sender_id", "name": "sender_id", "type": "uuid", "nullable": false, "primaryKey": false, "unique": false },
        { "id": "messages.content", "name": "content", "type": "text", "nullable": false, "primaryKey": false, "unique": false },
        { "id": "messages.reply_to_id", "name": "reply_to_id", "type": "uuid", "nullable": true, "primaryKey": false, "unique": false, "description": "Thread replies reference a parent message." },
        { "id": "messages.edited_at", "name": "edited_at", "type": "timestamptz", "nullable": true, "primaryKey": false, "unique": false },
        { "id": "messages.deleted_at", "name": "deleted_at", "type": "timestamptz", "nullable": true, "primaryKey": false, "unique": false, "description": "Soft-delete timestamp." },
        { "id": "messages.created_at", "name": "created_at", "type": "timestamptz", "nullable": false, "primaryKey": false, "unique": false, "default": "now()" }
      ],
      "indexes": [{ "id": "messages.channel_idx", "name": "messages_channel_created_idx", "table": "messages", "columns": ["messages.channel_id","messages.created_at"], "unique": false, "method": "btree" }, { "id": "messages.sender_idx", "name": "messages_sender_idx", "table": "messages", "columns": ["messages.sender_id"], "unique": false }, { "id": "messages.reply_idx", "name": "messages_reply_idx", "table": "messages", "columns": ["messages.reply_to_id"], "unique": false, "where": "reply_to_id IS NOT NULL" }]
    },
    {
      "id": "reactions", "name": "reactions", "description": "Emoji reactions on messages.",
      "columns": [
        { "id": "reactions.id", "name": "id", "type": "uuid", "nullable": false, "primaryKey": true, "unique": true, "default": "gen_random_uuid()" },
        { "id": "reactions.message_id", "name": "message_id", "type": "uuid", "nullable": false, "primaryKey": false, "unique": false },
        { "id": "reactions.user_id", "name": "user_id", "type": "uuid", "nullable": false, "primaryKey": false, "unique": false },
        { "id": "reactions.emoji", "name": "emoji", "type": "text", "nullable": false, "primaryKey": false, "unique": false },
        { "id": "reactions.created_at", "name": "created_at", "type": "timestamptz", "nullable": false, "primaryKey": false, "unique": false, "default": "now()" }
      ],
      "indexes": [{ "id": "reactions.message_idx", "name": "reactions_message_idx", "table": "reactions", "columns": ["reactions.message_id"], "unique": false }, { "id": "reactions.unique_idx", "name": "reactions_unique_idx", "table": "reactions", "columns": ["reactions.message_id","reactions.user_id","reactions.emoji"], "unique": true }, { "id": "reactions.reactions_user_id_idx", "name": "reactions_user_id_idx", "table": "reactions", "columns": ["reactions.user_id"], "unique": false, "method": "btree" }]
    },
    {
      "id": "attachments", "name": "attachments", "description": "Files uploaded with messages.",
      "columns": [
        { "id": "attachments.id", "name": "id", "type": "uuid", "nullable": false, "primaryKey": true, "unique": true, "default": "gen_random_uuid()" },
        { "id": "attachments.message_id", "name": "message_id", "type": "uuid", "nullable": false, "primaryKey": false, "unique": false },
        { "id": "attachments.file_name", "name": "file_name", "type": "text", "nullable": false, "primaryKey": false, "unique": false },
        { "id": "attachments.file_url", "name": "file_url", "type": "text", "nullable": false, "primaryKey": false, "unique": false },
        { "id": "attachments.mime_type", "name": "mime_type", "type": "text", "nullable": false, "primaryKey": false, "unique": false },
        { "id": "attachments.size_bytes", "name": "size_bytes", "type": "bigint", "nullable": false, "primaryKey": false, "unique": false },
        { "id": "attachments.created_at", "name": "created_at", "type": "timestamptz", "nullable": false, "primaryKey": false, "unique": false, "default": "now()" }
      ],
      "indexes": [{ "id": "attachments.message_idx", "name": "attachments_message_idx", "table": "attachments", "columns": ["attachments.message_id"], "unique": false }]
    }
  ],
  "enums": [
    { "id": "user_presence", "name": "user_presence", "values": ["online", "away", "dnd", "offline"], "description": "User online status indicator." },
    { "id": "channel_type", "name": "channel_type", "values": ["public", "private", "direct"], "description": "Channel visibility and behavior type." },
    { "id": "member_role", "name": "member_role", "values": ["owner", "admin", "member"], "description": "User role within a channel." }
  ],
  "relations": [
    { "id": "channels_created_by", "name": "channels_created_by", "from": { "table": "channels", "columns": ["channels.created_by"] }, "to": { "table": "users", "columns": ["users.id"] }, "cardinality": "many-to-one", "onDelete": "restrict" },
    { "id": "channel_members_channel", "name": "channel_members_channel", "from": { "table": "channel_members", "columns": ["channel_members.channel_id"] }, "to": { "table": "channels", "columns": ["channels.id"] }, "cardinality": "many-to-one", "onDelete": "cascade" },
    { "id": "channel_members_user", "name": "channel_members_user", "from": { "table": "channel_members", "columns": ["channel_members.user_id"] }, "to": { "table": "users", "columns": ["users.id"] }, "cardinality": "many-to-one", "onDelete": "cascade" },
    { "id": "messages_channel", "name": "messages_channel", "from": { "table": "messages", "columns": ["messages.channel_id"] }, "to": { "table": "channels", "columns": ["channels.id"] }, "cardinality": "many-to-one", "onDelete": "cascade" },
    { "id": "messages_sender", "name": "messages_sender", "from": { "table": "messages", "columns": ["messages.sender_id"] }, "to": { "table": "users", "columns": ["users.id"] }, "cardinality": "many-to-one", "onDelete": "cascade" },
    { "id": "messages_reply", "name": "messages_reply", "from": { "table": "messages", "columns": ["messages.reply_to_id"] }, "to": { "table": "messages", "columns": ["messages.id"] }, "cardinality": "many-to-one", "onDelete": "set-null" },
    { "id": "reactions_message", "name": "reactions_message", "from": { "table": "reactions", "columns": ["reactions.message_id"] }, "to": { "table": "messages", "columns": ["messages.id"] }, "cardinality": "many-to-one", "onDelete": "cascade" },
    { "id": "reactions_user", "name": "reactions_user", "from": { "table": "reactions", "columns": ["reactions.user_id"] }, "to": { "table": "users", "columns": ["users.id"] }, "cardinality": "many-to-one", "onDelete": "cascade" },
    { "id": "attachments_message", "name": "attachments_message", "from": { "table": "attachments", "columns": ["attachments.message_id"] }, "to": { "table": "messages", "columns": ["messages.id"] }, "cardinality": "many-to-one", "onDelete": "cascade" }
  ],
  "metadata": {
    "editor": {
      "tablePositions": {
        "users": { "x": 60, "y": 240 },
        "channels": { "x": 460, "y": 60 },
        "channel_members": { "x": 460, "y": 380 },
        "messages": { "x": 880, "y": 240 },
        "reactions": { "x": 1280, "y": 60 },
        "attachments": { "x": 1280, "y": 420 }
      }
    }
  }
}
