{
  "name": "@titanbase/core",
  "version": "0.1.0",
  "description": "Portable database schema format — types, validation, and diagnostics for .titan.json files.",
  "license": "MIT",
  "author": "Titanbase Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/titanbaserun/titanbase.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/titanbaserun/titanbase",
  "keywords": ["database", "schema", "postgres", "visual-editor", "json-schema", "ddl"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
