{
  "name": "@titanbase/import-postgres",
  "version": "0.5.0",
  "description": "Local PostgreSQL DDL importer for Titanbase schemas.",
  "license": "Apache-2.0",
  "author": "Titanbase Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/titanbaserun/titanbase.git",
    "directory": "packages/import-postgres"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@titanbase/core": "workspace:*"
  },
  "devDependencies": {
    "@titanbase/export-drizzle": "workspace:*",
    "@titanbase/export-mermaid": "workspace:*",
    "@titanbase/export-postgres": "workspace:*",
    "@titanbase/export-prisma": "workspace:*",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@titanbase/core": ">=0.3.0"
  }
}
