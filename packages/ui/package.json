{
  "name": "@titanbase/ui",
  "version": "0.2.0",
  "description": "Shared UI components for the Titanbase visual editor.",
  "license": "Apache-2.0",
  "author": "Titanbase Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/titanbaserun/titanbase.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/titanbaserun/titanbase",
  "keywords": ["ui", "react", "components", "titanbase"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  }
}
